@ComprasVentas_HostAddress = http://localhost:5171
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..8TWWOlnXnZK-sD1-s4ZoLvTp0HWsxBSFtDF55W3vVX4

###############################################################################
# AUTH
###############################################################################

### Login
POST {{ComprasVentas_HostAddress}}/api/auth/login
Content-Type: application/json
Accept: application/json

{
    "Email": "Luisa90@yahoo.com",
    "Password": "Password123*"
}

### Refresh Token
POST {{ComprasVentas_HostAddress}}/api/auth/refresh-token
Content-Type: application/json
Accept: application/json

{
    "RefreshToken": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=="
}

###############################################################################
# CATEGORIA (Requires Authorization)
###############################################################################

### Get all categorias
GET {{ComprasVentas_HostAddress}}/api/categoria
Accept: application/json
Authorization: Bearer {{authToken}}

### Get categoria by id
GET {{ComprasVentas_HostAddress}}/api/categoria/1
Accept: application/json
Authorization: Bearer {{authToken}}

### Create categoria
POST {{ComprasVentas_HostAddress}}/api/categoria
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{authToken}}

{
    "Nombre": "Nueva Categoria",
    "Descripcion": "Descripcion de la nueva categoria"
}

### Update categoria
PUT {{ComprasVentas_HostAddress}}/api/categoria/1
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{authToken}}

{
    "Nombre": "Categoria Actualizada",
    "Descripcion": "Descripcion actualizada"
}

### Delete categoria
DELETE {{ComprasVentas_HostAddress}}/api/categoria/1
Accept: application/json
Authorization: Bearer {{authToken}}

###############################################################################
# PERMISO
###############################################################################

### Get all permisos
GET {{ComprasVentas_HostAddress}}/api/permiso
Accept: application/json

### Get permiso by id
GET {{ComprasVentas_HostAddress}}/api/permiso/45
Accept: application/json

### Create permiso
POST {{ComprasVentas_HostAddress}}/api/permiso
Content-Type: application/json
Accept: application/json

{
    "Nombre": "Ver Reportes",
    "Recurso": "Reportes",
    "Action": "ver_reportes"
}

### Update permiso
PUT {{ComprasVentas_HostAddress}}/api/permiso/1
Content-Type: application/json
Accept: application/json

{
    "Nombre": "Ver Reportes Actualizado",
    "Recurso": "Reportes",
    "Action": "ver_reportes"
}

### Delete permiso
DELETE {{ComprasVentas_HostAddress}}/api/permiso/1
Accept: application/json

###############################################################################
# ROL
###############################################################################

### Get all roles
GET {{ComprasVentas_HostAddress}}/api/rol
Accept: application/json

### Get rol by id
GET {{ComprasVentas_HostAddress}}/api/rol/1
Accept: application/json

### Create rol
POST {{ComprasVentas_HostAddress}}/api/rol
Content-Type: application/json
Accept: application/json

{
    "Nombre": "Auditor",
    "Descripcion": "Rol con permisos de solo lectura",
    "PermisoIds": [1, 2, 3]
}

### Update rol
PUT {{ComprasVentas_HostAddress}}/api/rol/1
Content-Type: application/json
Accept: application/json

{
    "Nombre": "Auditor Actualizado",
    "Descripcion": "Descripcion actualizada del rol auditor",
    "PermisoIds": [1, 2]
}

### Delete rol
DELETE {{ComprasVentas_HostAddress}}/api/rol/1
Accept: application/json

